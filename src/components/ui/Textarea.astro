---
interface Props {
  label: string;
  name: string;
  value?: string;
  placeholder?: string;
  required?: boolean;
  rows?: number;
  error?: string;
  class?: string;
}

const {
  label,
  name,
  value = '',
  placeholder = '',
  required = false,
  rows = 4,
  error,
  class: className = '',
} = Astro.props;
---

<div class:list={['space-y-1', className]}>
  <label for={name} class="block text-sm font-medium text-gray-700">
    {label}
    {required && <span class="text-red-500 ml-1">*</span>}
  </label>
  <textarea
    id={name}
    name={name}
    placeholder={placeholder}
    required={required}
    rows={rows}
    class:list={[
      'w-full px-3 py-2 border rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 resize-none',
      error ? 'border-red-500' : 'border-gray-300',
    ]}
  >{value}</textarea>
  {error && (
    <p class="text-sm text-red-600">{error}</p>
  )}
</div>
