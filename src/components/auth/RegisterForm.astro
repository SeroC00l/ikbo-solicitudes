---
import Button from '@/components/ui/Button.astro';
import Input from '@/components/ui/Input.astro';
---

<form id="register-form" class="space-y-6">
  <Input
    label="Full Name"
    name="fullName"
    required
    placeholder="John Doe"
  />

  <Input
    label="Company"
    name="empresa"
    required
    placeholder="Fresh Flowers Inc."
  />

  <Input
    label="Email"
    name="email"
    type="email"
    required
    placeholder="you@example.com"
  />

  <Input
    label="Password"
    name="password"
    type="password"
    required
    placeholder="••••••••"
  />

  <div class="space-y-2">
    <label class="block text-sm font-medium text-gray-700">Role</label>
    <div class="grid grid-cols-3 gap-3">
      <label class="relative flex items-center justify-center p-3 border rounded-lg cursor-pointer hover:bg-gray-50">
        <input type="radio" name="rol" value="comprador" class="sr-only" checked />
        <div class="text-center">
          <span class="text-2xl">🛒</span>
          <span class="mt-1 block text-sm font-medium">Buyer</span>
        </div>
      </label>
      <label class="relative flex items-center justify-center p-3 border rounded-lg cursor-pointer hover:bg-gray-50">
        <input type="radio" name="rol" value="vendedor" class="sr-only" />
        <div class="text-center">
          <span class="text-2xl">🌾</span>
          <span class="mt-1 block text-sm font-medium">Seller</span>
        </div>
      </label>
      <label class="relative flex items-center justify-center p-3 border rounded-lg cursor-pointer hover:bg-gray-50">
        <input type="radio" name="rol" value="ambos" class="sr-only" />
        <div class="text-center">
          <span class="text-2xl">🤝</span>
          <span class="mt-1 block text-sm font-medium">Both</span>
        </div>
      </label>
    </div>
  </div>

  <div id="error-message" class="hidden text-sm text-red-600 bg-red-50 p-3 rounded-lg"></div>

  <Button type="submit" class="w-full" id="register-btn">
    Create Account
  </Button>

  <p class="text-center text-sm text-gray-600">
    Already have an account?
    <a href="/login" class="font-medium text-pink-600 hover:text-pink-500">
      Sign in
    </a>
  </p>
</form>

<script>
  import { supabase } from '@/lib/supabase';

  const form = document.getElementById('register-form') as HTMLFormElement;
  const errorDiv = document.getElementById('error-message');
  const registerBtn = document.getElementById('register-btn');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const formData = new FormData(form);
    const fullName = formData.get('fullName') as string;
    const empresa = formData.get('empresa') as string;
    const email = formData.get('email') as string;
    const password = formData.get('password') as string;
    const rol = formData.get('rol') as string;

    if (password.length < 6) {
      if (errorDiv) {
        errorDiv.textContent = 'Password must be at least 6 characters';
        errorDiv.classList.remove('hidden');
      }
      return;
    }

    if (errorDiv) errorDiv.classList.add('hidden');
    if (registerBtn) registerBtn.setAttribute('disabled', 'true');

    try {
      const { data, error } = await supabase.auth.signUp({ email, password });
      if (error) throw error;

      const { error: profileError } = await supabase.from('usuarios').insert({
        id: data.user!.id,
        email,
        full_name: fullName,
        empresa,
        rol: rol as any,
      });
      if (profileError) throw profileError;

      alert('Account created successfully. Please sign in.');
      window.location.href = '/login';
    } catch (error) {
      if (errorDiv) {
        errorDiv.textContent = (error as Error).message;
        errorDiv.classList.remove('hidden');
      }
    } finally {
      if (registerBtn) registerBtn.removeAttribute('disabled');
    }
  });
</script>
