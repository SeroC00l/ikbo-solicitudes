---
import Button from '@/components/ui/Button.astro';
import Input from '@/components/ui/Input.astro';
---

<form id="register-form" class="space-y-6">
  <Input
    label="Nombre Completo"
    name="fullName"
    required
    placeholder="Juan Pérez"
  />

  <Input
    label="Empresa"
    name="empresa"
    required
    placeholder="Mi Empresa S.A."
  />

  <Input
    label="Correo Electrónico"
    name="email"
    type="email"
    required
    placeholder="tu@ejemplo.com"
  />

  <Input
    label="Contraseña"
    name="password"
    type="password"
    required
    placeholder="••••••••"
  />

  <div class="space-y-2">
    <label class="block text-sm font-medium text-gray-700">Rol</label>
    <div class="grid grid-cols-3 gap-3">
      <label class="relative flex items-center justify-center p-3 border rounded-lg cursor-pointer hover:bg-gray-50">
        <input type="radio" name="rol" value="cliente" class="sr-only" checked />
        <div class="text-center">
          <svg class="w-6 h-6 mx-auto text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
          <span class="mt-1 block text-sm font-medium">Cliente</span>
        </div>
      </label>
      <label class="relative flex items-center justify-center p-3 border rounded-lg cursor-pointer hover:bg-gray-50">
        <input type="radio" name="rol" value="proveedor" class="sr-only" />
        <div class="text-center">
          <svg class="w-6 h-6 mx-auto text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
          </svg>
          <span class="mt-1 block text-sm font-medium">Proveedor</span>
        </div>
      </label>
      <label class="relative flex items-center justify-center p-3 border rounded-lg cursor-pointer hover:bg-gray-50">
        <input type="radio" name="rol" value="ambos" class="sr-only" />
        <div class="text-center">
          <svg class="w-6 h-6 mx-auto text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
          </svg>
          <span class="mt-1 block text-sm font-medium">Ambos</span>
        </div>
      </label>
    </div>
  </div>

  <div id="error-message" class="hidden text-sm text-red-600 bg-red-50 p-3 rounded-lg"></div>

  <Button type="submit" class="w-full" id="register-btn">
    Crear Cuenta
  </Button>

  <p class="text-center text-sm text-gray-600">
    ¿Ya tienes una cuenta?
    <a href="/login" class="font-medium text-blue-600 hover:text-blue-500">
      Inicia sesión
    </a>
  </p>
</form>

<script>
  import { supabase } from '@/lib/supabase';

  const form = document.getElementById('register-form') as HTMLFormElement;
  const errorDiv = document.getElementById('error-message');
  const registerBtn = document.getElementById('register-btn');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const formData = new FormData(form);
    const fullName = formData.get('fullName') as string;
    const empresa = formData.get('empresa') as string;
    const email = formData.get('email') as string;
    const password = formData.get('password') as string;
    const rol = formData.get('rol') as string;

    if (errorDiv) errorDiv.classList.add('hidden');
    if (registerBtn) registerBtn.setAttribute('disabled', 'true');

    try {
      const { data, error } = await supabase.auth.signUp({
        email,
        password,
      });

      if (error) throw error;

      const { error: profileError } = await supabase.from('usuarios').insert({
        id: data.user!.id,
        email,
        full_name: fullName,
        empresa,
        rol: rol as any,
      });

      if (profileError) throw profileError;

      alert('Cuenta creada exitosamente. Por favor inicia sesión.');
      window.location.href = '/login';
    } catch (error) {
      if (errorDiv) {
        errorDiv.textContent = (error as Error).message;
        errorDiv.classList.remove('hidden');
      }
    } finally {
      if (registerBtn) registerBtn.removeAttribute('disabled');
    }
  });
</script>
