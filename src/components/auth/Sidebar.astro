---
import { APP_NAME, ROUTES } from '@/lib/constants';

const pathname = Astro.url.pathname;

const menuItems = [
  { label: 'Dashboard', href: ROUTES.DASHBOARD, icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6' },
  { label: 'Contracts', href: ROUTES.CONTRACTS, icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2' },
  { label: 'Offers', href: ROUTES.OFFERS, icon: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z' },
];

function isActive(href: string): boolean {
  if (href === ROUTES.DASHBOARD) return pathname === ROUTES.DASHBOARD;
  return pathname.startsWith(href);
}
---

<aside class="w-64 bg-gradient-to-b from-pink-600 to-pink-800 text-white min-h-screen p-4 relative flex flex-col">
  <div class="mb-8">
    <h2 class="text-xl font-bold flex items-center gap-2">
      <span class="text-2xl">🌸</span>
      {APP_NAME}
    </h2>
  </div>

  <nav class="space-y-2 flex-1">
    {menuItems.map((item) => (
      <a
        href={item.href}
        class:list={[
          'flex items-center space-x-3 px-4 py-2 rounded-lg transition-colors',
          isActive(item.href) ? 'bg-pink-700 text-white' : 'text-pink-200 hover:bg-pink-700',
        ]}
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={item.icon} />
        </svg>
        <span>{item.label}</span>
      </a>
    ))}
  </nav>

  <div>
    <button
      id="logout-btn"
      class="w-full flex items-center space-x-3 px-4 py-2 rounded-lg hover:bg-pink-700 transition-colors text-pink-200"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
      </svg>
      <span>Log Out</span>
    </button>
  </div>
</aside>

<script>
  import { supabase } from '@/lib/supabase';

  document.getElementById('logout-btn')?.addEventListener('click', async () => {
    await supabase.auth.signOut();
    localStorage.removeItem('user');
    window.location.href = '/login';
  });
</script>
