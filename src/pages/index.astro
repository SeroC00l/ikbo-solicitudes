---
import LayoutPrincipal from '@/layouts/LayoutPrincipal.astro';
import Button from '@/components/ui/Button.astro';
---

<LayoutPrincipal title="FlorFutures - Contratos de Futuros de Flores">
  <div class="min-h-screen flex items-center justify-center">
    <div class="text-center space-y-8 px-4">
      <div class="flex justify-center">
        <span class="text-6xl">🌸</span>
      </div>
      <h1 class="text-5xl font-bold text-gray-900">
        FlorFutures
      </h1>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto">
        Plataforma de contratos de futuros para flores premium.
        Conectamos compradores y vendedores para acordar precios y cantidades de toneladas de flores frescas.
      </p>
      
      <div class="flex justify-center gap-4">
        <a href="/login">
          <Button size="lg">
            Iniciar Sesión
          </Button>
        </a>
        <a href="/registro">
          <Button variant="secondary" size="lg">
            Crear Cuenta
          </Button>
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-16 max-w-4xl mx-auto">
        <div class="bg-white p-6 rounded-lg shadow-md">
          <div class="w-12 h-12 bg-pink-100 rounded-lg flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl">🌹</span>
          </div>
          <h3 class="text-lg font-semibold text-gray-900">Flores Premium</h3>
          <p class="text-gray-600 mt-2">Rosa, Clavel, Lirio, Gerbera y más variedades frescas de Colombia y el mundo.</p>
        </div>

        <div class="bg-white p-6 rounded-lg shadow-md">
          <div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl">📊</span>
          </div>
          <h3 class="text-lg font-semibold text-gray-900">Contratos de Futuros</h3>
          <p class="text-gray-600 mt-2">Acuerda precios y cantidades de toneladas para entrega futura con total seguridad.</p>
        </div>

        <div class="bg-white p-6 rounded-lg shadow-md">
          <div class="w-12 h-12 bg-purple-100 rounded-lg flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl">🤝</span>
          </div>
          <h3 class="text-lg font-semibold text-gray-900">Negociación Segura</h3>
          <p class="text-gray-600 mt-2">Ofertas, contraofertas y decisiones de aceptación/rechazo con total transparencia.</p>
        </div>
      </div>

      <div class="mt-16 grid grid-cols-2 md:grid-cols-4 gap-4 max-w-3xl mx-auto">
        <div class="text-center p-4">
          <span class="text-3xl">🌷</span>
        </div>
        <div class="text-center p-4">
          <span class="text-3xl">🌺</span>
        </div>
        <div class="text-center p-4">
          <span class="text-3xl">🌻</span>
        </div>
        <div class="text-center p-4">
          <span class="text-3xl">🌼</span>
        </div>
      </div>
    </div>
  </div>
</LayoutPrincipal>
