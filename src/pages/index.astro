---
import LayoutPrincipal from '@/layouts/LayoutPrincipal.astro';
import Button from '@/components/ui/Button.astro';
---

<LayoutPrincipal title="FlorFutures - Flower Futures Trading">
  <div id="app" class="min-h-screen flex items-center justify-center">
    <div class="text-center space-y-8 px-4">
      <div class="flex justify-center">
        <span class="text-6xl">🌸</span>
      </div>
      <h1 class="text-5xl font-bold text-gray-900">
        FlorFutures
      </h1>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto">
        Flower futures trading platform.
        Connecting buyers and sellers to agree on prices and tonnage of fresh flowers.
      </p>

      <div class="flex justify-center gap-4">
        <a href="/login">
          <Button size="lg">Sign In</Button>
        </a>
        <a href="/register">
          <Button variant="secondary" size="lg">Create Account</Button>
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-16 max-w-4xl mx-auto">
        <div class="bg-white p-6 rounded-lg shadow-md">
          <div class="w-12 h-12 bg-pink-100 rounded-lg flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl">🌹</span>
          </div>
          <h3 class="text-lg font-semibold text-gray-900">Premium Flowers</h3>
          <p class="text-gray-600 mt-2">Rose, Carnation, Lily, Gerbera and more fresh varieties from Colombia and around the world.</p>
        </div>

        <div class="bg-white p-6 rounded-lg shadow-md">
          <div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl">📊</span>
          </div>
          <h3 class="text-lg font-semibold text-gray-900">Futures Contracts</h3>
          <p class="text-gray-600 mt-2">Agree on prices and tonnage for future delivery with complete security.</p>
        </div>

        <div class="bg-white p-6 rounded-lg shadow-md">
          <div class="w-12 h-12 bg-purple-100 rounded-lg flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl">🤝</span>
          </div>
          <h3 class="text-lg font-semibold text-gray-900">Safe Trading</h3>
          <p class="text-gray-600 mt-2">Offers, counteroffers and accept/reject decisions with full transparency.</p>
        </div>
      </div>

      <div class="mt-16 grid grid-cols-2 md:grid-cols-4 gap-4 max-w-3xl mx-auto">
        <div class="text-center p-4"><span class="text-3xl">🌷</span></div>
        <div class="text-center p-4"><span class="text-3xl">🌺</span></div>
        <div class="text-center p-4"><span class="text-3xl">🌻</span></div>
        <div class="text-center p-4"><span class="text-3xl">🌼</span></div>
      </div>
    </div>
  </div>
</LayoutPrincipal>

<script>
  import { supabase } from '@/lib/supabase';

  async function checkSession() {
    const { data: { session } } = await supabase.auth.getSession();
    if (session) {
      const { data: profile } = await supabase
        .from('usuarios').select('*').eq('id', session.user.id).maybeSingle();
      if (profile) {
        localStorage.setItem('user', JSON.stringify(profile));
        window.location.href = '/dashboard';
      }
    }
  }
  checkSession();
</script>
