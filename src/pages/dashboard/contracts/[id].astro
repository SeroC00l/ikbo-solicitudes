---
export const prerender = false;

import LayoutDashboard from '@/layouts/LayoutDashboard.astro';

const { id } = Astro.params;
---

<LayoutDashboard title="Contract Details">
  <div class="max-w-4xl mx-auto space-y-6">
    <div class="flex justify-between items-center">
      <div>
        <a href="/dashboard/contracts" class="text-blue-600 hover:text-blue-800 text-sm">← Back to contracts</a>
        <h1 class="text-3xl font-bold text-gray-900 mt-2">Contract Details</h1>
      </div>
    </div>

    <div id="contract-detail" class="bg-white rounded-lg shadow-md p-6">
      <p class="text-gray-600">Loading details...</p>
    </div>
  </div>
</LayoutDashboard>

<script>
  import { supabase } from '@/lib/supabase';
  import { escapeHtml } from '@/lib/sanitize';
  import { getCurrentUser } from '@/lib/auth';

  const container = document.getElementById('contract-detail');
  const urlParts = window.location.pathname.split('/');
  const contractId = urlParts[urlParts.length - 1];
  let currentUser: Awaited<ReturnType<typeof getCurrentUser>> = null;

  if (!contractId) {
    window.location.href = '/dashboard/contracts';
  } else {
    loadContract();
  }

  async function loadContract() {
    if (!currentUser) {
      currentUser = await getCurrentUser();
      if (!currentUser) { window.location.href = '/login'; return; }
    }
    // Fetch contract with buyer (single row, no one-to-many join)
    const { data: contract, error: contractError } = await supabase
      .from('contratos')
      .select('*, comprador:usuarios(*)')
      .eq('id', contractId)
      .single();

    if (contractError || !contract) {
      if (container) container.innerHTML = `<div class="text-center py-8 text-red-600">Error: ${escapeHtml(contractError?.message || 'Not found')}</div>`;
      return;
    }

    // Fetch items separately (avoids one-to-many join duplication)
    const { data: items } = await supabase
      .from('contrato_items')
      .select('*, flor:flores(*)')
      .eq('contrato_id', contractId);

    // Fetch offers for all items
    const itemIds = (items || []).map(i => i.id);
    let offers: any[] = [];
    if (itemIds.length > 0) {
      const { data } = await supabase
        .from('ofertas')
        .select('*, vendedor:usuarios(*)')
        .in('contrato_item_id', itemIds);
      offers = data || [];
    }

    // Fetch counteroffers for all offers
    const offerIds = offers.map(o => o.id);
    let counteroffers: any[] = [];
    if (offerIds.length > 0) {
      const { data } = await supabase
        .from('contraofertas')
        .select('*, comprador:usuarios(*)')
        .in('oferta_id', offerIds);
      counteroffers = data || [];
    }

    // Assemble nested structure
    for (const item of (items || [])) {
      item.ofertas = offers
        .filter(o => o.contrato_item_id === item.id)
        .map(o => ({
          ...o,
          contraofertas: counteroffers.filter(c => c.oferta_id === o.id),
        }));
    }
    contract.items = items || [];

    const user = currentUser;
    const isOwner = user?.id === contract.comprador_id;
    const isSeller = user?.rol === 'vendedor' || user?.rol === 'ambos';

    if (container) {
      container.innerHTML = `
        <div class="space-y-6">
          <div class="border-b pb-4">
            <div class="flex justify-between items-start">
              <div>
                <h2 class="text-2xl font-bold text-gray-900">${escapeHtml(contract.titulo)}</h2>
                <p class="text-gray-600 mt-1">Created by: ${escapeHtml(contract.comprador?.full_name || 'N/A')}</p>
              </div>
              <span class="px-3 py-1 rounded-full text-sm font-medium ${getColor(contract.estado)}">
                ${escapeHtml(contract.estado.toUpperCase())}
              </span>
            </div>
            <p class="text-gray-700 mt-4">${escapeHtml(contract.descripcion)}</p>
            <p class="text-sm text-gray-500 mt-2">Delivery: ${new Date(contract.fecha_entrega).toLocaleDateString()}</p>
            <p class="text-sm font-semibold text-gray-900 mt-1">Total: $${contract.precio_total?.toFixed(2) || '0.00'}</p>
          </div>

          <div>
            <h3 class="text-lg font-semibold text-gray-900 mb-4">Flowers</h3>
            <div class="space-y-4">
              ${contract.items.map((item: any) => `
                <div class="bg-gray-50 p-4 rounded-lg">
                  <div class="flex justify-between items-start">
                    <div>
                      <h4 class="font-medium text-gray-900">${escapeHtml(item.flor?.nombre || 'Flower not found')}</h4>
                      <p class="text-sm text-gray-600">Type: ${escapeHtml(item.flor?.tipo || 'N/A')} | Origin: ${escapeHtml(item.flor?.origen || 'N/A')}</p>
                      <p class="text-sm text-gray-600">${escapeHtml(item.especificaciones || 'No specs')}</p>
                    </div>
                    <div class="text-right">
                      <p class="text-lg font-semibold text-gray-900">${item.toneladas} tons</p>
                      <p class="text-sm text-gray-600">$${item.precio_por_tonelada}/ton</p>
                    </div>
                  </div>

                  ${item.ofertas && item.ofertas.length > 0 ? `
                    <div class="mt-4 border-t pt-4">
                      <h5 class="text-sm font-medium text-gray-700 mb-2">Received offers:</h5>
                      <div class="space-y-2">
                        ${item.ofertas.map((oferta: any) => `
                          <div class="bg-white p-3 rounded border">
                            <div class="flex justify-between items-center">
                              <div>
                                <p class="font-medium text-gray-900">${escapeHtml(oferta.vendedor?.full_name || 'Seller')}</p>
                                <p class="text-sm text-gray-600">$${oferta.precio_por_tonelada}/ton = $${oferta.precio_total}</p>
                                <p class="text-xs text-gray-500">Delivery in ${oferta.tiempo_entrega_dias} days</p>
                              </div>
                              <span class="px-2 py-1 text-xs font-medium rounded-full ${getColor(oferta.estado)}">
                                ${escapeHtml(oferta.estado)}
                              </span>
                            </div>
                            ${oferta.condiciones ? `<p class="text-sm text-gray-600 mt-2">${escapeHtml(oferta.condiciones)}</p>` : ''}

                            ${isOwner && oferta.estado === 'pendiente' ? `
                              <div class="mt-3 flex gap-2">
                                <button class="accept-offer px-3 py-1 bg-green-600 text-white text-sm rounded hover:bg-green-700" data-id="${oferta.id}">Accept</button>
                                <button class="reject-offer px-3 py-1 bg-red-600 text-white text-sm rounded hover:bg-red-700" data-id="${oferta.id}">Reject</button>
                                <button class="counter-btn px-3 py-1 bg-purple-600 text-white text-sm rounded hover:bg-purple-700" data-id="${oferta.id}">Counter</button>
                              </div>
                            ` : ''}

                            ${oferta.contraofertas && oferta.contraofertas.length > 0 ? `
                              <div class="mt-3 space-y-2">
                                ${oferta.contraofertas.map((co: any) => `
                                  <div class="bg-purple-50 p-2 rounded border border-purple-200">
                                    <div class="flex justify-between items-center">
                                      <div>
                                        <p class="text-sm font-medium text-gray-900">${escapeHtml(co.comprador?.full_name || 'Buyer')}</p>
                                        <p class="text-sm text-purple-700 font-semibold">$${co.precio_por_tonelada}/ton</p>
                                        ${co.mensaje ? `<p class="text-xs text-gray-600">${escapeHtml(co.mensaje)}</p>` : ''}
                                      </div>
                                      <span class="px-2 py-1 text-xs font-medium rounded-full ${getColor(co.estado)}">${escapeHtml(co.estado)}</span>
                                    </div>
                                  </div>
                                `).join('')}
                              </div>
                            ` : ''}
                          </div>
                        `).join('')}
                      </div>
                    </div>
                  ` : ''}

                  ${isSeller && !item.ofertas?.some((o: any) => o.vendedor_id === user.id) ? `
                    <div class="mt-4">
                      <button class="create-offer-btn px-4 py-2 bg-blue-600 text-white text-sm rounded hover:bg-blue-700" data-item-id="${item.id}" data-precio="${item.precio_por_tonelada}" data-toneladas="${item.toneladas}">Create Offer</button>
                    </div>
                  ` : ''}
                </div>
              `).join('') || '<p class="text-gray-500">No flowers in this contract</p>'}
            </div>
          </div>
        </div>
      `;

      // Event listeners
      document.querySelectorAll('.accept-offer').forEach(btn => {
        btn.addEventListener('click', async (e) => {
          const ofertaId = (e.currentTarget as HTMLElement).dataset.id!;
          await supabase.from('ofertas').update({ estado: 'aceptada' }).eq('id', ofertaId);
          // Reject other pending offers for same item
          const { data: oferta } = await supabase.from('ofertas').select('contrato_item_id').eq('id', ofertaId).single();
          if (oferta) {
            await supabase.from('ofertas').update({ estado: 'rechazada' }).eq('contrato_item_id', oferta.contrato_item_id).eq('estado', 'pendiente').neq('id', ofertaId);
          }
          loadContract();
        });
      });

      document.querySelectorAll('.reject-offer').forEach(btn => {
        btn.addEventListener('click', async (e) => {
          const ofertaId = (e.currentTarget as HTMLElement).dataset.id!;
          await supabase.from('ofertas').update({ estado: 'rechazada' }).eq('id', ofertaId);
          loadContract();
        });
      });

      document.querySelectorAll('.counter-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          const ofertaId = (e.currentTarget as HTMLElement).dataset.id!;
          showCounterofferModal(ofertaId);
        });
      });

      document.querySelectorAll('.create-offer-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          const el = e.currentTarget as HTMLElement;
          showOfferModal(el.dataset.itemId!, el.dataset.precio!, el.dataset.toneladas!);
        });
      });
    }
  }

  function showOfferModal(itemId: string, precioRef: string, toneladas: string) {
    const modal = document.createElement('div');
    modal.className = 'fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50';
    modal.innerHTML = `
      <div class="bg-white p-6 rounded-lg w-full max-w-md">
        <h3 class="text-lg font-semibold mb-4">Create Offer</h3>
        <form id="offer-form" class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-gray-700">Price per Ton (USD)</label>
            <input type="number" name="precio_unitario" step="0.01" value="${precioRef}" required class="w-full px-3 py-2 border rounded-lg" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700">Delivery Time (days)</label>
            <input type="number" name="tiempo_entrega" required class="w-full px-3 py-2 border rounded-lg" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700">Conditions</label>
            <textarea name="condiciones" rows="3" class="w-full px-3 py-2 border rounded-lg" placeholder="Offer conditions..."></textarea>
          </div>
          <div class="flex gap-2 justify-end">
            <button type="button" class="cancel-modal px-4 py-2 border rounded-lg">Cancel</button>
            <button type="submit" class="px-4 py-2 bg-blue-600 text-white rounded-lg">Submit Offer</button>
          </div>
        </form>
      </div>
    `;
    document.body.appendChild(modal);

    modal.querySelector('.cancel-modal')?.addEventListener('click', () => modal.remove());
    modal.querySelector('#offer-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(e.target as HTMLFormElement);
      if (!currentUser) return;
      const precio = parseFloat(formData.get('precio_unitario') as string);

      await supabase.from('ofertas').insert({
        contrato_item_id: itemId,
        vendedor_id: currentUser!.id,
        precio_por_tonelada: precio,
        precio_total: precio * parseFloat(toneladas),
        tiempo_entrega_dias: parseInt(formData.get('tiempo_entrega') as string),
        condiciones: formData.get('condiciones') as string || null,
        estado: 'pendiente',
      });

      modal.remove();
      loadContract();
    });
  }

  function showCounterofferModal(ofertaId: string) {
    const modal = document.createElement('div');
    modal.className = 'fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50';
    modal.innerHTML = `
      <div class="bg-white p-6 rounded-lg w-full max-w-md">
        <h3 class="text-lg font-semibold mb-4">Counteroffer</h3>
        <form id="counter-form" class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-gray-700">Your price per ton</label>
            <input type="number" name="precio_unitario" step="0.01" required class="w-full px-3 py-2 border rounded-lg" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700">Message</label>
            <textarea name="mensaje" rows="3" class="w-full px-3 py-2 border rounded-lg" placeholder="Explain your counteroffer..."></textarea>
          </div>
          <div class="flex gap-2 justify-end">
            <button type="button" class="cancel-modal px-4 py-2 border rounded-lg">Cancel</button>
            <button type="submit" class="px-4 py-2 bg-purple-600 text-white rounded-lg">Submit Counteroffer</button>
          </div>
        </form>
      </div>
    `;
    document.body.appendChild(modal);

    modal.querySelector('.cancel-modal')?.addEventListener('click', () => modal.remove());
    modal.querySelector('#counter-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(e.target as HTMLFormElement);
      if (!currentUser) return;

      await supabase.from('contraofertas').insert({
        oferta_id: ofertaId,
        comprador_id: currentUser.id,
        precio_por_tonelada: parseFloat(formData.get('precio_unitario') as string),
        mensaje: formData.get('mensaje') as string || null,
        estado: 'pendiente',
      });

      await supabase.from('ofertas').update({ estado: 'contraoferta' }).eq('id', ofertaId);

      modal.remove();
      loadContract();
    });
  }

  function getColor(estado: string) {
    const colors: Record<string, string> = {
      pendiente: 'bg-yellow-100 text-yellow-800',
      aceptado: 'bg-blue-100 text-blue-800',
      aceptada: 'bg-green-100 text-green-800',
      en_proceso: 'bg-blue-100 text-blue-800',
      completado: 'bg-green-100 text-green-800',
      cancelado: 'bg-red-100 text-red-800',
      rechazada: 'bg-red-100 text-red-800',
      contraoferta: 'bg-purple-100 text-purple-800',
      vencido: 'bg-gray-100 text-gray-800',
    };
    return colors[estado] || 'bg-gray-100 text-gray-800';
  }
</script>
