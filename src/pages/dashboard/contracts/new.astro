---
import LayoutDashboard from '@/layouts/LayoutDashboard.astro';
import Button from '@/components/ui/Button.astro';
import Input from '@/components/ui/Input.astro';
import Textarea from '@/components/ui/Textarea.astro';
---

<LayoutDashboard title="New Contract">
  <div class="max-w-4xl mx-auto space-y-6">
    <div class="flex items-center gap-4">
      <span class="text-3xl">📝</span>
      <div>
        <h1 class="text-3xl font-bold text-gray-900">New Futures Contract</h1>
        <p class="mt-2 text-gray-600">Create a new contract for flower purchase/sale</p>
      </div>
    </div>

    <form id="contract-form" class="bg-white p-6 rounded-lg shadow-md space-y-6">
      <Input
        label="Contract Title"
        name="titulo"
        required
        placeholder="e.g. Purchase of 50 tons of Red Roses"
      />

      <Textarea
        label="Description"
        name="descripcion"
        required
        placeholder="Describe the contract details..."
        rows={4}
      />

      <Input
        label="Delivery Date"
        name="fecha_entrega"
        type="date"
        required
      />

      <div class="border-t pt-6">
        <div class="flex justify-between items-center mb-4">
          <h3 class="text-lg font-semibold text-gray-900">Contract Items</h3>
          <Button type="button" variant="secondary" id="add-item-btn">
            <span class="mr-2">➕</span>
            Add Flower
          </Button>
        </div>

        <div id="items-container" class="space-y-4"></div>
      </div>

      <div id="error-message" class="hidden text-sm text-red-600 bg-red-50 p-3 rounded-lg"></div>

      <div class="flex justify-end gap-4">
        <a href="/dashboard/contracts">
          <Button variant="secondary" type="button">Cancel</Button>
        </a>
        <Button type="submit" id="submit-btn">Create Contract</Button>
      </div>
    </form>
  </div>
</LayoutDashboard>

<script>
  import { supabase } from '@/lib/supabase';
  import { escapeHtml } from '@/lib/sanitize';

  const form = document.getElementById('contract-form') as HTMLFormElement;
  const itemsContainer = document.getElementById('items-container');
  const addItemBtn = document.getElementById('add-item-btn');
  const errorDiv = document.getElementById('error-message');
  const submitBtn = document.getElementById('submit-btn');

  let items: Array<{ florId: string; toneladas: number; precioPorTonelada: number; especificaciones: string }> = [];
  let flores: Array<{ id: string; nombre: string; tipo: string }> = [];

  async function ensureProfile() {
    let userStr = localStorage.getItem('user');
    if (userStr) return JSON.parse(userStr);

    const { data: { session } } = await supabase.auth.getSession();
    if (!session) { window.location.href = '/login'; return null; }

    let { data: profile } = await supabase
      .from('usuarios').select('*').eq('id', session.user.id).maybeSingle();
    if (!profile) {
      const email = session.user.email || '';
      await supabase.from('usuarios').insert({
        id: session.user.id, email, full_name: email.split('@')[0],
        empresa: 'My Company', rol: 'comprador',
      });
      const { data: p2 } = await supabase.from('usuarios').select('*').eq('id', session.user.id).maybeSingle();
      profile = p2;
    }
    if (!profile) { window.location.href = '/login'; return null; }
    localStorage.setItem('user', JSON.stringify(profile));
    return profile;
  }

  async function loadFlores() {
    const { data } = await supabase.from('flores').select('*').order('nombre');
    if (data) { flores = data; renderItems(); }
  }

  ensureProfile().then(() => loadFlores());

  addItemBtn?.addEventListener('click', () => {
    items.push({ florId: '', toneladas: 1, precioPorTonelada: 0, especificaciones: '' });
    renderItems();
  });

  function renderItems() {
    if (!itemsContainer) return;

    if (items.length === 0) {
      itemsContainer.innerHTML = `
        <div class="text-center py-8 text-gray-500">
          No flowers added. Click "Add Flower" to add products to your contract.
        </div>
      `;
      return;
    }

    itemsContainer.innerHTML = items.map((item, index) => `
      <div class="bg-gray-50 p-4 rounded-lg border" data-index="${index}">
        <div class="flex justify-between items-start mb-4">
          <h4 class="font-medium text-gray-900">Flower ${index + 1}</h4>
          <button type="button" class="text-red-600 hover:text-red-800 remove-item" data-index="${index}">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
            </svg>
          </button>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Flower Type</label>
            <select class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-pink-500 flor-select" data-index="${index}">
              <option value="">Select flower</option>
              ${flores.map(f => `<option value="${f.id}" ${item.florId === f.id ? 'selected' : ''}>${escapeHtml(f.nombre)} (${escapeHtml(f.tipo)})</option>`).join('')}
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Tonnage</label>
            <input type="number" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-pink-500 toneladas-input" data-index="${index}" value="${item.toneladas}" min="0.1" step="0.1" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Price per Ton (USD)</label>
            <input type="number" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-pink-500 precio-input" data-index="${index}" value="${item.precioPorTonelada}" min="0" step="0.01" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Specifications</label>
            <input type="text" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-pink-500 specs-input" data-index="${index}" value="${escapeHtml(item.especificaciones)}" placeholder="Additional specs..." />
          </div>
        </div>
        <div class="mt-3 text-right">
          <span class="text-sm text-gray-600">Total: </span>
          <span class="font-semibold text-gray-900">$${(item.toneladas * item.precioPorTonelada).toFixed(2)}</span>
        </div>
      </div>
    `).join('');

    document.querySelectorAll('.remove-item').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const idx = parseInt((e.currentTarget as HTMLElement).dataset.index || '0');
        items.splice(idx, 1);
        renderItems();
      });
    });

    document.querySelectorAll('.flor-select').forEach(select => {
      select.addEventListener('change', (e) => {
        const idx = parseInt((e.currentTarget as HTMLElement).dataset.index || '0');
        items[idx].florId = (e.target as HTMLSelectElement).value;
      });
    });

    document.querySelectorAll('.toneladas-input').forEach(input => {
      input.addEventListener('change', (e) => {
        const idx = parseInt((e.currentTarget as HTMLElement).dataset.index || '0');
        items[idx].toneladas = parseFloat((e.target as HTMLInputElement).value) || 1;
        renderItems();
      });
    });

    document.querySelectorAll('.precio-input').forEach(input => {
      input.addEventListener('change', (e) => {
        const idx = parseInt((e.currentTarget as HTMLElement).dataset.index || '0');
        items[idx].precioPorTonelada = parseFloat((e.target as HTMLInputElement).value) || 0;
        renderItems();
      });
    });

    document.querySelectorAll('.specs-input').forEach(input => {
      input.addEventListener('change', (e) => {
        const idx = parseInt((e.currentTarget as HTMLElement).dataset.index || '0');
        items[idx].especificaciones = (e.target as HTMLInputElement).value;
      });
    });
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const formData = new FormData(form);
    const titulo = formData.get('titulo') as string;
    const descripcion = formData.get('descripcion') as string;
    const fecha_entrega = formData.get('fecha_entrega') as string;

    if (items.length === 0) {
      if (errorDiv) { errorDiv.textContent = 'Add at least one flower to the contract'; errorDiv.classList.remove('hidden'); }
      return;
    }

    if (items.some(item => !item.florId)) {
      if (errorDiv) { errorDiv.textContent = 'Each item must have a flower selected'; errorDiv.classList.remove('hidden'); }
      return;
    }

    if (errorDiv) errorDiv.classList.add('hidden');
    if (submitBtn) submitBtn.setAttribute('disabled', 'true');

    try {
      const user = JSON.parse(localStorage.getItem('user') || '{}');
      const precioTotal = items.reduce((sum, item) => sum + (item.toneladas * item.precioPorTonelada), 0);

      const { data: contrato, error: contratoError } = await supabase
        .from('contratos')
        .insert({
          comprador_id: user.id,
          titulo,
          descripcion,
          fecha_entrega,
          precio_total: precioTotal,
          estado: 'pendiente',
        })
        .select()
        .single();

      if (contratoError) throw contratoError;

      const itemsToInsert = items.map(item => ({
        contrato_id: contrato.id,
        flor_id: item.florId,
        toneladas: item.toneladas,
        precio_por_tonelada: item.precioPorTonelada,
        especificaciones: item.especificaciones || null,
      }));

      const { error: itemsError } = await supabase.from('contrato_items').insert(itemsToInsert);
      if (itemsError) throw itemsError;

      window.location.href = '/dashboard/contracts';
    } catch (error) {
      if (errorDiv) { errorDiv.textContent = (error as Error).message; errorDiv.classList.remove('hidden'); }
    } finally {
      if (submitBtn) submitBtn.removeAttribute('disabled');
    }
  });
</script>
