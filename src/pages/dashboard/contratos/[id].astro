---
export const prerender = false;

import LayoutDashboard from '@/layouts/LayoutDashboard.astro';
import Button from '@/components/ui/Button.astro';
import Badge from '@/components/ui/Badge.astro';

const { id } = Astro.params;
---

<LayoutDashboard title="Detalle de Contrato">
  <div class="max-w-4xl mx-auto space-y-6">
    <div class="flex justify-between items-center">
      <div>
        <a href="/dashboard/contratos" class="text-blue-600 hover:text-blue-800 text-sm">
          ← Volver a contratos
        </a>
        <h1 class="text-3xl font-bold text-gray-900 mt-2">Detalle de Contrato</h1>
      </div>
    </div>

    <div id="contrato-detail" class="bg-white rounded-lg shadow-md p-6">
      <p class="text-gray-600">Cargando detalles...</p>
    </div>
  </div>
</LayoutDashboard>

<script>
  import { supabase } from '@/lib/supabase';

  const container = document.getElementById('contrato-detail');
  const urlParts = window.location.pathname.split('/');
  const contratoId = urlParts[urlParts.length - 1];

  if (!contratoId) {
    window.location.href = '/dashboard/contratos';
  } else {
    loadContrato();
  }

  async function loadContrato() {
    const { data, error } = await supabase
      .from('contratos')
      .select('*, comprador:usuarios(*), items:contrato_items(*, flor:flores(*), ofertas(*, vendedor:usuarios(*), contraofertas(*, comprador:usuarios(*))))')
      .eq('id', contratoId)
      .single();

    if (error || !data) {
      if (container) {
        container.innerHTML = `
          <div class="text-center py-8 text-red-600">
            Error al cargar el contrato: ${error?.message || 'No encontrado'}
          </div>
        `;
      }
      return;
    }

    const user = JSON.parse(localStorage.getItem('user') || '{}');
    const isOwner = user.id === data.comprador_id;
    const isVendedor = user.rol === 'vendedor' || user.rol === 'ambos';

    if (container) {
      container.innerHTML = `
        <div class="space-y-6">
          <div class="border-b pb-4">
            <div class="flex justify-between items-start">
              <div>
                <h2 class="text-2xl font-bold text-gray-900">${data.titulo}</h2>
                <p class="text-gray-600 mt-1">Creado por: ${data.comprador?.full_name || 'N/A'}</p>
              </div>
              <span class="px-3 py-1 rounded-full text-sm font-medium ${getEstadoColor(data.estado)}">
                ${data.estado.toUpperCase()}
              </span>
            </div>
            <p class="text-gray-700 mt-4">${data.descripcion}</p>
            <p class="text-sm text-gray-500 mt-2">
              Fecha de entrega: ${new Date(data.fecha_entrega).toLocaleDateString('es-ES')}
            </p>
            <p class="text-sm font-semibold text-gray-900 mt-1">
              Precio Total: $${data.precio_total?.toFixed(2) || '0.00'}
            </p>
          </div>

          <div>
            <h3 class="text-lg font-semibold text-gray-900 mb-4">Flores del Contrato</h3>
            <div class="space-y-4">
              ${data.items?.map((item: any) => `
                <div class="bg-gray-50 p-4 rounded-lg">
                  <div class="flex justify-between items-start">
                    <div>
                      <h4 class="font-medium text-gray-900">${item.flor?.nombre || 'Flor no encontrada'}</h4>
                      <p class="text-sm text-gray-600">Tipo: ${item.flor?.tipo || 'N/A'} | Origen: ${item.flor?.origen || 'N/A'}</p>
                      <p class="text-sm text-gray-600">${item.especificaciones || 'Sin especificaciones'}</p>
                    </div>
                    <div class="text-right">
                      <p class="text-lg font-semibold text-gray-900">${item.toneladas} toneladas</p>
                      <p class="text-sm text-gray-600">$${item.precio_por_tonelada}/tonelada</p>
                    </div>
                  </div>
                  
                  ${item.ofertas && item.ofertas.length > 0 ? `
                    <div class="mt-4 border-t pt-4">
                      <h5 class="text-sm font-medium text-gray-700 mb-2">Ofertas recibidas:</h5>
                      <div class="space-y-2">
                        ${item.ofertas.map((oferta: any) => `
                          <div class="bg-white p-3 rounded border">
                            <div class="flex justify-between items-center">
                              <div>
                                <p class="font-medium text-gray-900">${oferta.vendedor?.full_name || 'Vendedor'}</p>
                                <p class="text-sm text-gray-600">$${oferta.precio_por_tonelada}/ton = $${oferta.precio_total}</p>
                                <p class="text-xs text-gray-500">Entrega en ${oferta.tiempo_entrega_dias} días</p>
                              </div>
                              <span class="px-2 py-1 text-xs font-medium rounded-full ${getEstadoColor(oferta.estado)}">
                                ${oferta.estado}
                              </span>
                            </div>
                            ${oferta.condiciones ? `<p class="text-sm text-gray-600 mt-2">${oferta.condiciones}</p>` : ''}
                            
                            ${isOwner && oferta.estado === 'pendiente' ? `
                              <div class="mt-3 flex gap-2">
                                <button class="aceptar-oferta px-3 py-1 bg-green-600 text-white text-sm rounded hover:bg-green-700" data-id="${oferta.id}">
                                  Aceptar
                                </button>
                                <button class="rechazar-oferta px-3 py-1 bg-red-600 text-white text-sm rounded hover:bg-red-700" data-id="${oferta.id}">
                                  Rechazar
                                </button>
                                <button class="contraoferta-btn px-3 py-1 bg-purple-600 text-white text-sm rounded hover:bg-purple-700" data-id="${oferta.id}" data-item-id="${item.id}">
                                  Contraofertar
                                </button>
                              </div>
                            ` : ''}
                          </div>
                        `).join('')}
                      </div>
                    </div>
                  ` : ''}
                  
                  ${isVendedor && !item.ofertas?.some((o: any) => o.vendedor_id === user.id) ? `
                    <div class="mt-4">
                      <button class="crear-oferta-btn px-4 py-2 bg-blue-600 text-white text-sm rounded hover:bg-blue-700" data-item-id="${item.id}" data-precio="${item.precio_por_tonelada}" data-toneladas="${item.toneladas}">
                        Crear Oferta
                      </button>
                    </div>
                  ` : ''}
                </div>
              `).join('') || '<p class="text-gray-500">No hay flores en este contrato</p>'}
            </div>
          </div>
        </div>
      `;

      // Add event listeners
      document.querySelectorAll('.aceptar-oferta').forEach(btn => {
        btn.addEventListener('click', async (e) => {
          const ofertaId = (e.currentTarget as HTMLElement).dataset.id;
          await updateOfertaEstado(ofertaId, 'aceptada');
        });
      });

      document.querySelectorAll('.rechazar-oferta').forEach(btn => {
        btn.addEventListener('click', async (e) => {
          const ofertaId = (e.currentTarget as HTMLElement).dataset.id;
          await updateOfertaEstado(ofertaId, 'rechazada');
        });
      });

      document.querySelectorAll('.contraoferta-btn').forEach(btn => {
        btn.addEventListener('click', async (e) => {
          const ofertaId = (e.currentTarget as HTMLElement).dataset.id;
          const itemId = (e.currentTarget as HTMLElement).dataset.itemId;
          showContraofertaForm(ofertaId, itemId);
        });
      });

      document.querySelectorAll('.crear-oferta-btn').forEach(btn => {
        btn.addEventListener('click', async (e) => {
          const itemId = (e.currentTarget as HTMLElement).dataset.itemId;
          const precio = (e.currentTarget as HTMLElement).dataset.precio;
          const toneladas = (e.currentTarget as HTMLElement).dataset.toneladas;
          showOfertaForm(itemId, precio, toneladas);
        });
      });
    }
  }

  function showOfertaForm(itemId: string, precioRef: string, toneladas: string) {
    const modal = document.createElement('div');
    modal.className = 'fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50';
    modal.innerHTML = `
      <div class="bg-white p-6 rounded-lg w-full max-w-md">
        <h3 class="text-lg font-semibold mb-4">Crear Oferta</h3>
        <form id="oferta-form" class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-gray-700">Precio por Tonelada (USD)</label>
            <input type="number" name="precio_unitario" step="0.01" value="${precioRef}" required class="w-full px-3 py-2 border rounded-lg" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700">Tiempo de Entrega (días)</label>
            <input type="number" name="tiempo_entrega" required class="w-full px-3 py-2 border rounded-lg" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700">Condiciones</label>
            <textarea name="condiciones" rows="3" class="w-full px-3 py-2 border rounded-lg" placeholder="Condiciones de la oferta..."></textarea>
          </div>
          <div class="flex gap-2 justify-end">
            <button type="button" class="cancelar-modal px-4 py-2 border rounded-lg">Cancelar</button>
            <button type="submit" class="px-4 py-2 bg-blue-600 text-white rounded-lg">Enviar Oferta</button>
          </div>
        </form>
      </div>
    `;
    document.body.appendChild(modal);

    modal.querySelector('.cancelar-modal')?.addEventListener('click', () => modal.remove());
    modal.querySelector('#oferta-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(e.target as HTMLFormElement);
      const user = JSON.parse(localStorage.getItem('user') || '{}');
      const precioUnitario = parseFloat(formData.get('precio_unitario') as string);
      const precioTotal = precioUnitario * parseFloat(toneladas);
      
      await supabase.from('ofertas').insert({
        contrato_item_id: itemId,
        vendedor_id: user.id,
        precio_por_tonelada: precioUnitario,
        precio_total: precioTotal,
        tiempo_entrega_dias: parseInt(formData.get('tiempo_entrega') as string),
        condiciones: formData.get('condiciones') as string,
        estado: 'pendiente',
      });

      modal.remove();
      loadContrato();
    });
  }

  function showContraofertaForm(ofertaId: string, itemId: string) {
    const modal = document.createElement('div');
    modal.className = 'fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50';
    modal.innerHTML = `
      <div class="bg-white p-6 rounded-lg w-full max-w-md">
        <h3 class="text-lg font-semibold mb-4">Contraofertar</h3>
        <form id="contraoferta-form" class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-gray-700">Tu precio propuesto (por tonelada)</label>
            <input type="number" name="precio_unitario" step="0.01" required class="w-full px-3 py-2 border rounded-lg" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700">Mensaje</label>
            <textarea name="mensaje" rows="3" class="w-full px-3 py-2 border rounded-lg" placeholder="Explica tu contraoferta..."></textarea>
          </div>
          <div class="flex gap-2 justify-end">
            <button type="button" class="cancelar-modal px-4 py-2 border rounded-lg">Cancelar</button>
            <button type="submit" class="px-4 py-2 bg-purple-600 text-white rounded-lg">Enviar Contraoferta</button>
          </div>
        </form>
      </div>
    `;
    document.body.appendChild(modal);

    modal.querySelector('.cancelar-modal')?.addEventListener('click', () => modal.remove());
    modal.querySelector('#contraoferta-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(e.target as HTMLFormElement);
      const user = JSON.parse(localStorage.getItem('user') || '{}');
      
      await supabase.from('contraofertas').insert({
        oferta_id: ofertaId,
        comprador_id: user.id,
        precio_por_tonelada: parseFloat(formData.get('precio_unitario') as string),
        mensaje: formData.get('mensaje') as string,
        estado: 'pendiente',
      });

      await supabase.from('ofertas').update({ estado: 'contraoferta' }).eq('id', ofertaId);

      modal.remove();
      loadContrato();
    });
  }

  async function updateOfertaEstado(ofertaId: string, estado: string) {
    await supabase.from('ofertas').update({ estado }).eq('id', ofertaId);
    loadContrato();
  }

  function getEstadoColor(estado: string) {
    const colors: Record<string, string> = {
      pendiente: 'bg-yellow-100 text-yellow-800',
      aceptado: 'bg-blue-100 text-blue-800',
      en_proceso: 'bg-blue-100 text-blue-800',
      completado: 'bg-green-100 text-green-800',
      cancelado: 'bg-red-100 text-red-800',
      vencido: 'bg-gray-100 text-gray-800',
      aceptada: 'bg-green-100 text-green-800',
      rechazada: 'bg-red-100 text-red-800',
      contraoferta: 'bg-purple-100 text-purple-800',
    };
    return colors[estado] || 'bg-gray-100 text-gray-800';
  }
</script>
