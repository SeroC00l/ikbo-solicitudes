---
import LayoutDashboard from '@/layouts/LayoutDashboard.astro';
import Button from '@/components/ui/Button.astro';
---

<LayoutDashboard title="Contratos">
  <div class="space-y-6">
    <div class="flex justify-between items-center">
      <div class="flex items-center gap-4">
        <span class="text-3xl">📋</span>
        <div>
          <h1 class="text-3xl font-bold text-gray-900">Contratos de Futuros</h1>
          <p class="mt-2 text-gray-600">Gestiona tus contratos de compra/venta de flores</p>
        </div>
      </div>
      <a href="/dashboard/contratos/nuevo">
        <Button>
          <span class="mr-2">➕</span>
          Nuevo Contrato
        </Button>
      </a>
    </div>

    <div id="contratos-container" class="bg-white rounded-lg shadow-md">
      <div class="p-6 text-center text-gray-600">
        Cargando contratos...
      </div>
    </div>
  </div>
</LayoutDashboard>

<script>
  import { supabase } from '@/lib/supabase';

  const container = document.getElementById('contratos-container');
  const userStr = localStorage.getItem('user');

  if (!userStr) {
    window.location.href = '/login';
  } else {
    loadContratos();
  }

  async function loadContratos() {
    const user = JSON.parse(localStorage.getItem('user') || '{}');
    
    let query = supabase
      .from('contratos')
      .select('*, comprador:usuarios(*), items:contrato_items(*, flor:flores(*))')
      .order('created_at', { ascending: false });

    if (user.rol === 'comprador') {
      query = query.eq('comprador_id', user.id);
    }

    const { data, error } = await query;

    if (error) {
      if (container) {
        container.innerHTML = `
          <div class="p-6 text-center text-red-600">
            Error al cargar contratos: ${error.message}
          </div>
        `;
      }
      return;
    }

    if (!data || data.length === 0) {
      if (container) {
        container.innerHTML = `
          <div class="p-6 text-center text-gray-600">
            No hay contratos disponibles. Crea uno nuevo para empezar.
          </div>
        `;
      }
      return;
    }

    if (container) {
      container.innerHTML = `
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Título</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Comprador</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Estado</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Items</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Fecha Entrega</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Acciones</th>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              ${data.map(contrato => `
                <tr class="hover:bg-gray-50">
                  <td class="px-6 py-4 whitespace-nowrap">
                    <div class="text-sm font-medium text-gray-900">${contrato.titulo}</div>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <div class="text-sm text-gray-900">${contrato.comprador?.full_name || 'N/A'}</div>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full ${getEstadoColor(contrato.estado)}">
                      ${contrato.estado}
                    </span>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                    ${contrato.items?.length || 0} items
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                    ${new Date(contrato.fecha_entrega).toLocaleDateString('es-ES')}
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                    <a href="/dashboard/contratos/${contrato.id}" class="text-blue-600 hover:text-blue-900">
                      Ver detalles
                    </a>
                  </td>
                </tr>
              `).join('')}
            </tbody>
          </table>
        </div>
      `;
    }
  }

  function getEstadoColor(estado: string) {
    const colors: Record<string, string> = {
      pendiente: 'bg-yellow-100 text-yellow-800',
      aceptado: 'bg-blue-100 text-blue-800',
      en_proceso: 'bg-blue-100 text-blue-800',
      completado: 'bg-green-100 text-green-800',
      cancelado: 'bg-red-100 text-red-800',
      vencido: 'bg-gray-100 text-gray-800',
    };
    return colors[estado] || 'bg-gray-100 text-gray-800';
  }
</script>
