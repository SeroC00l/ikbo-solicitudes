---
import LayoutDashboard from '@/layouts/LayoutDashboard.astro';
import Button from '@/components/ui/Button.astro';
---

<LayoutDashboard title="Ofertas">
  <div class="space-y-6">
    <div class="flex items-center gap-4">
      <span class="text-3xl">💰</span>
      <div>
        <h1 class="text-3xl font-bold text-gray-900">Ofertas</h1>
        <p class="mt-2 text-gray-600">Gestiona las ofertas de vendedores de flores</p>
      </div>
    </div>

    <div id="ofertas-container" class="bg-white rounded-lg shadow-md">
      <div class="p-6 text-center text-gray-600">
        Cargando ofertas...
      </div>
    </div>
  </div>
</LayoutDashboard>

<script>
  import { supabase } from '@/lib/supabase';

  const container = document.getElementById('ofertas-container');
  const userStr = localStorage.getItem('user');

  if (!userStr) {
    window.location.href = '/login';
  } else {
    loadOfertas();
  }

  async function loadOfertas() {
    const user = JSON.parse(localStorage.getItem('user') || '{}');
    
    let query = supabase
      .from('ofertas')
      .select('*, vendedor:usuarios(*), contrato_item:contrato_items(*, contrato:contratos(*), flor:flores(*)), contraofertas(*, comprador:usuarios(*))')
      .order('created_at', { ascending: false });

    if (user.rol === 'vendedor') {
      query = query.eq('vendedor_id', user.id);
    }

    const { data, error } = await query;

    if (error) {
      if (container) {
        container.innerHTML = `
          <div class="p-6 text-center text-red-600">
            Error al cargar ofertas: ${error.message}
          </div>
        `;
      }
      return;
    }

    if (!data || data.length === 0) {
      if (container) {
        container.innerHTML = `
          <div class="p-6 text-center text-gray-600">
            No hay ofertas disponibles.
          </div>
        `;
      }
      return;
    }

    if (container) {
      container.innerHTML = `
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Flor</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Vendedor</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Precio</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Estado</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Acciones</th>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              ${data.map(oferta => `
                <tr class="hover:bg-gray-50">
                  <td class="px-6 py-4 whitespace-nowrap">
                    <div class="text-sm font-medium text-gray-900">${oferta.contrato_item?.flor?.nombre || 'N/A'}</div>
                    <div class="text-sm text-gray-500">${oferta.contrato_item?.contrato?.titulo || ''}</div>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <div class="text-sm text-gray-900">${oferta.vendedor?.full_name || 'N/A'}</div>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <div class="text-sm font-medium text-gray-900">$${oferta.precio_por_tonelada}/ton</div>
                    <div class="text-sm text-gray-500">Total: $${oferta.precio_total}</div>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full ${getEstadoColor(oferta.estado)}">
                      ${oferta.estado}
                    </span>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                    <a href="/dashboard/ofertas/${oferta.id}" class="text-blue-600 hover:text-blue-900">
                      Ver detalles
                    </a>
                  </td>
                </tr>
              `).join('')}
            </tbody>
          </table>
        </div>
      `;
    }
  }

  function getEstadoColor(estado: string) {
    const colors: Record<string, string> = {
      pendiente: 'bg-yellow-100 text-yellow-800',
      aceptada: 'bg-green-100 text-green-800',
      rechazada: 'bg-red-100 text-red-800',
      contraoferta: 'bg-purple-100 text-purple-800',
    };
    return colors[estado] || 'bg-gray-100 text-gray-800';
  }
</script>
