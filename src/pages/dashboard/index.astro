---
import LayoutDashboard from '@/layouts/LayoutDashboard.astro';
---

<LayoutDashboard title="Dashboard">
  <div class="space-y-8">
    <div class="flex items-center gap-4">
      <span class="text-4xl">🌸</span>
      <div>
        <h1 class="text-3xl font-bold text-gray-900">Dashboard</h1>
        <p class="mt-2 text-gray-600">Bienvenido a FlorFutures - Contratos de Futuros de Flores</p>
      </div>
    </div>

    <div id="user-info" class="bg-white p-6 rounded-lg shadow-md">
      <p class="text-gray-600">Cargando información del usuario...</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <a href="/dashboard/contratos" class="block bg-white p-6 rounded-lg shadow-md hover:shadow-lg transition-shadow">
        <div class="flex items-center space-x-4">
          <div class="w-12 h-12 bg-pink-100 rounded-lg flex items-center justify-center">
            <span class="text-2xl">📋</span>
          </div>
          <div>
            <h3 class="text-lg font-semibold text-gray-900">Mis Contratos</h3>
            <p class="text-gray-600">Gestionar contratos de futuros</p>
          </div>
        </div>
      </a>

      <a href="/dashboard/ofertas" class="block bg-white p-6 rounded-lg shadow-md hover:shadow-lg transition-shadow">
        <div class="flex items-center space-x-4">
          <div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center">
            <span class="text-2xl">💰</span>
          </div>
          <div>
            <h3 class="text-lg font-semibold text-gray-900">Ofertas Recibidas</h3>
            <p class="text-gray-600">Ver y responder a ofertas</p>
          </div>
        </div>
      </a>

      <a href="/dashboard/contratos/nuevo" class="block bg-white p-6 rounded-lg shadow-md hover:shadow-lg transition-shadow">
        <div class="flex items-center space-x-4">
          <div class="w-12 h-12 bg-purple-100 rounded-lg flex items-center justify-center">
            <span class="text-2xl">➕</span>
          </div>
          <div>
            <h3 class="text-lg font-semibold text-gray-900">Nuevo Contrato</h3>
            <p class="text-gray-600">Crear un nuevo contrato</p>
          </div>
        </div>
      </a>
    </div>
  </div>
</LayoutDashboard>

<script>
  const userInfo = document.getElementById('user-info');
  const userStr = localStorage.getItem('user');
  
  if (!userStr) {
    window.location.href = '/login';
  } else {
    const user = JSON.parse(userStr);
    if (userInfo) {
      userInfo.innerHTML = `
        <h2 class="text-xl font-semibold text-gray-900">Bienvenido, ${user.full_name}</h2>
        <p class="text-gray-600 mt-1">Empresa: ${user.empresa}</p>
        <p class="text-gray-600">Rol: <span class="font-medium capitalize">${user.rol}</span></p>
      `;
    }
  }
</script>
