---
import LayoutDashboard from '@/layouts/LayoutDashboard.astro';
---

<LayoutDashboard title="Dashboard">
  <div class="space-y-8">
    <div class="flex items-center gap-4">
      <span class="text-4xl">🌸</span>
      <div>
        <h1 class="text-3xl font-bold text-gray-900">Dashboard</h1>
        <p class="mt-2 text-gray-600">Welcome to FlorFutures</p>
      </div>
    </div>

    <div id="user-info" class="bg-white p-6 rounded-lg shadow-md">
      <p class="text-gray-600">Loading user info...</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <a href="/dashboard/contracts" class="block bg-white p-6 rounded-lg shadow-md hover:shadow-lg transition-shadow">
        <div class="flex items-center space-x-4">
          <div class="w-12 h-12 bg-pink-100 rounded-lg flex items-center justify-center">
            <span class="text-2xl">📋</span>
          </div>
          <div>
            <h3 class="text-lg font-semibold text-gray-900">My Contracts</h3>
            <p class="text-gray-600">Manage futures contracts</p>
          </div>
        </div>
      </a>

      <a href="/dashboard/offers" class="block bg-white p-6 rounded-lg shadow-md hover:shadow-lg transition-shadow">
        <div class="flex items-center space-x-4">
          <div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center">
            <span class="text-2xl">💰</span>
          </div>
          <div>
            <h3 class="text-lg font-semibold text-gray-900">Offers</h3>
            <p class="text-gray-600">View and respond to offers</p>
          </div>
        </div>
      </a>

      <a href="/dashboard/contracts/new" class="block bg-white p-6 rounded-lg shadow-md hover:shadow-lg transition-shadow">
        <div class="flex items-center space-x-4">
          <div class="w-12 h-12 bg-purple-100 rounded-lg flex items-center justify-center">
            <span class="text-2xl text-gray-600">➕</span>
          </div>
          <div>
            <h3 class="text-lg font-semibold text-gray-900">New Contract</h3>
            <p class="text-gray-600">Create a new contract</p>
          </div>
        </div>
      </a>
    </div>
  </div>
</LayoutDashboard>

<script>
  import { supabase } from '@/lib/supabase';
  import { escapeHtml } from '@/lib/sanitize';

  async function ensureProfile(userId: string, email: string) {
    let { data: profile } = await supabase
      .from('usuarios').select('*').eq('id', userId).maybeSingle();
    if (!profile) {
      await supabase.from('usuarios').insert({
        id: userId,
        email,
        full_name: email.split('@')[0],
        empresa: 'My Company',
        rol: 'comprador',
      });
      const { data: newProfile } = await supabase
        .from('usuarios').select('*').eq('id', userId).maybeSingle();
      profile = newProfile;
    }
    return profile;
  }

  async function init() {
    const userStr = localStorage.getItem('user');
    if (!userStr) {
      const { data: { session } } = await supabase.auth.getSession();
      if (!session) { window.location.href = '/login'; return; }
      const profile = await ensureProfile(session.user.id, session.user.email || '');
      if (!profile) { window.location.href = '/login'; return; }
      localStorage.setItem('user', JSON.stringify(profile));
      renderUser(profile);
    } else {
      renderUser(JSON.parse(userStr));
    }
  }

  function renderUser(user: any) {
    const userInfo = document.getElementById('user-info');
    if (userInfo) {
      userInfo.innerHTML = `
        <h2 class="text-xl font-semibold text-gray-900">Welcome, ${escapeHtml(user.full_name)}</h2>
        <p class="text-gray-600 mt-1">Company: ${escapeHtml(user.empresa)}</p>
        <p class="text-gray-600">Role: <span class="font-medium capitalize">${escapeHtml(user.rol)}</span></p>
      `;
    }
  }

  init();
</script>
