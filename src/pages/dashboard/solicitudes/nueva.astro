---
import LayoutDashboard from '@/layouts/LayoutDashboard.astro';
import Button from '@/components/ui/Button.astro';
import Input from '@/components/ui/Input.astro';
import Textarea from '@/components/ui/Textarea.astro';
---

<LayoutDashboard title="Nueva Solicitud">
  <div class="max-w-4xl mx-auto space-y-6">
    <div>
      <h1 class="text-3xl font-bold text-gray-900">Nueva Solicitud</h1>
      <p class="mt-2 text-gray-600">Crea una nueva solicitud de productos</p>
    </div>

    <form id="solicitud-form" class="bg-white p-6 rounded-lg shadow-md space-y-6">
      <Input
        label="Título de la Solicitud"
        name="titulo"
        required
        placeholder="Ej: Solicitud de materiales de oficina"
      />

      <Textarea
        label="Descripción"
        name="descripcion"
        required
        placeholder="Describe los detalles de tu solicitud..."
        rows={4}
      />

      <Input
        label="Fecha Límite"
        name="fecha_limite"
        type="date"
        required
      />

      <div class="border-t pt-6">
        <div class="flex justify-between items-center mb-4">
          <h3 class="text-lg font-semibold text-gray-900">Items de la Solicitud</h3>
          <Button type="button" variant="secondary" id="add-item-btn">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
            </svg>
            Agregar Item
          </Button>
        </div>

        <div id="items-container" class="space-y-4">
          <!-- Items will be added here dynamically -->
        </div>
      </div>

      <div id="error-message" class="hidden text-sm text-red-600 bg-red-50 p-3 rounded-lg"></div>

      <div class="flex justify-end gap-4">
        <a href="/dashboard/solicitudes">
          <Button variant="secondary" type="button">
            Cancelar
          </Button>
        </a>
        <Button type="submit" id="submit-btn">
          Crear Solicitud
        </Button>
      </div>
    </form>
  </div>
</LayoutDashboard>

<script>
  import { supabase } from '@/lib/supabase';

  const form = document.getElementById('solicitud-form') as HTMLFormElement;
  const itemsContainer = document.getElementById('items-container');
  const addItemBtn = document.getElementById('add-item-btn');
  const errorDiv = document.getElementById('error-message');
  const submitBtn = document.getElementById('submit-btn');

  let items: Array<{ nombre: string; unidad: string; cantidad: number; especificaciones: string }> = [];
  let productos: Array<{ id: string; nombre: string; unidad: string }> = [];

  // Load products
  async function loadProductos() {
    const { data } = await supabase.from('productos').select('*').order('nombre');
    if (data) {
      productos = data;
      renderItems();
    }
  }

  loadProductos();

  addItemBtn?.addEventListener('click', () => {
    items.push({ nombre: '', unidad: '', cantidad: 1, especificaciones: '' });
    renderItems();
  });

  function renderItems() {
    if (!itemsContainer) return;

    if (items.length === 0) {
      itemsContainer.innerHTML = `
        <div class="text-center py-8 text-gray-500">
          No hay items. Haz clic en "Agregar Item" para añadir productos a tu solicitud.
        </div>
      `;
      return;
    }

    itemsContainer.innerHTML = items.map((item, index) => `
      <div class="bg-gray-50 p-4 rounded-lg border" data-index="${index}">
        <div class="flex justify-between items-start mb-4">
          <h4 class="font-medium text-gray-900">Item ${index + 1}</h4>
          <button type="button" class="text-red-600 hover:text-red-800 remove-item" data-index="${index}">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
            </svg>
          </button>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Producto</label>
            <select 
              class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 product-select"
              data-index="${index}"
            >
              <option value="">Seleccionar producto</option>
              ${productos.map(p => `
                <option value="${p.id}" ${item.nombre === p.id ? 'selected' : ''}>${p.nombre} (${p.unidad})</option>
              `).join('')}
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Cantidad</label>
            <input 
              type="number" 
              class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 quantity-input"
              data-index="${index}"
              value="${item.cantidad}"
              min="1"
            />
          </div>
          <div class="md:col-span-2">
            <label class="block text-sm font-medium text-gray-700 mb-1">Especificaciones</label>
            <input 
              type="text" 
              class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 specs-input"
              data-index="${index}"
              value="${item.especificaciones}"
              placeholder="Especificaciones adicionales..."
            />
          </div>
        </div>
      </div>
    `).join('');

    // Add event listeners
    document.querySelectorAll('.remove-item').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const index = parseInt((e.currentTarget as HTMLElement).dataset.index || '0');
        items.splice(index, 1);
        renderItems();
      });
    });

    document.querySelectorAll('.product-select').forEach(select => {
      select.addEventListener('change', (e) => {
        const index = parseInt((e.currentTarget as HTMLElement).dataset.index || '0');
        const productoId = (e.target as HTMLSelectElement).value;
        items[index].nombre = productoId;
      });
    });

    document.querySelectorAll('.quantity-input').forEach(input => {
      input.addEventListener('change', (e) => {
        const index = parseInt((e.currentTarget as HTMLElement).dataset.index || '0');
        items[index].cantidad = parseInt((e.target as HTMLInputElement).value) || 1;
      });
    });

    document.querySelectorAll('.specs-input').forEach(input => {
      input.addEventListener('change', (e) => {
        const index = parseInt((e.currentTarget as HTMLElement).dataset.index || '0');
        items[index].especificaciones = (e.target as HTMLInputElement).value;
      });
    });
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const formData = new FormData(form);
    const titulo = formData.get('titulo') as string;
    const descripcion = formData.get('descripcion') as string;
    const fecha_limite = formData.get('fecha_limite') as string;

    if (items.length === 0) {
      if (errorDiv) {
        errorDiv.textContent = 'Debe agregar al menos un item a la solicitud';
        errorDiv.classList.remove('hidden');
      }
      return;
    }

    if (errorDiv) errorDiv.classList.add('hidden');
    if (submitBtn) submitBtn.setAttribute('disabled', 'true');

    try {
      const user = JSON.parse(localStorage.getItem('user') || '{}');

      // Create solicitud
      const { data: solicitud, error: solicitudError } = await supabase
        .from('solicitudes')
        .insert({
          cliente_id: user.id,
          titulo,
          descripcion,
          fecha_limite,
          estado: 'pendiente',
        })
        .select()
        .single();

      if (solicitudError) throw solicitudError;

      // Create items
      const itemsToInsert = items.map(item => ({
        solicitud_id: solicitud.id,
        producto_id: item.nombre,
        cantidad: item.cantidad,
        especificaciones: item.especificaciones,
      }));

      const { error: itemsError } = await supabase
        .from('solicitud_items')
        .insert(itemsToInsert);

      if (itemsError) throw itemsError;

      window.location.href = '/dashboard/solicitudes';
    } catch (error) {
      if (errorDiv) {
        errorDiv.textContent = (error as Error).message;
        errorDiv.classList.remove('hidden');
      }
    } finally {
      if (submitBtn) submitBtn.removeAttribute('disabled');
    }
  });
</script>
