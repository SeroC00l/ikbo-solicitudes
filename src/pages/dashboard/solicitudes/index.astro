---
import LayoutDashboard from '@/layouts/LayoutDashboard.astro';
import Button from '@/components/ui/Button.astro';
---

<LayoutDashboard title="Solicitudes">
  <div class="space-y-6">
    <div class="flex justify-between items-center">
      <div>
        <h1 class="text-3xl font-bold text-gray-900">Solicitudes</h1>
        <p class="mt-2 text-gray-600">Gestiona tus solicitudes de productos</p>
      </div>
      <a href="/dashboard/solicitudes/nueva">
        <Button>
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
          </svg>
          Nueva Solicitud
        </Button>
      </a>
    </div>

    <div id="solicitudes-container" class="bg-white rounded-lg shadow-md">
      <div class="p-6 text-center text-gray-600">
        Cargando solicitudes...
      </div>
    </div>
  </div>
</LayoutDashboard>

<script>
  import { supabase } from '@/lib/supabase';

  const container = document.getElementById('solicitudes-container');
  const userStr = localStorage.getItem('user');

  if (!userStr) {
    window.location.href = '/login';
  } else {
    loadSolicitudes();
  }

  async function loadSolicitudes() {
    const user = JSON.parse(localStorage.getItem('user') || '{}');
    
    let query = supabase
      .from('solicitudes')
      .select('*, cliente:usuarios(*), items:solicitud_items(*, producto:productos(*))')
      .order('created_at', { ascending: false });

    if (user.rol === 'cliente') {
      query = query.eq('cliente_id', user.id);
    }

    const { data, error } = await query;

    if (error) {
      if (container) {
        container.innerHTML = `
          <div class="p-6 text-center text-red-600">
            Error al cargar solicitudes: ${error.message}
          </div>
        `;
      }
      return;
    }

    if (!data || data.length === 0) {
      if (container) {
        container.innerHTML = `
          <div class="p-6 text-center text-gray-600">
            No hay solicitudes disponibles.
          </div>
        `;
      }
      return;
    }

    if (container) {
      container.innerHTML = `
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Título</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Cliente</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Estado</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Items</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Fecha Límite</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Acciones</th>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              ${data.map(solicitud => `
                <tr class="hover:bg-gray-50">
                  <td class="px-6 py-4 whitespace-nowrap">
                    <div class="text-sm font-medium text-gray-900">${solicitud.titulo}</div>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <div class="text-sm text-gray-900">${solicitud.cliente?.full_name || 'N/A'}</div>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full ${getEstadoColor(solicitud.estado)}">
                      ${solicitud.estado}
                    </span>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                    ${solicitud.items?.length || 0} items
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                    ${new Date(solicitud.fecha_limite).toLocaleDateString('es-ES')}
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                    <a href="/dashboard/solicitudes/${solicitud.id}" class="text-blue-600 hover:text-blue-900">
                      Ver detalles
                    </a>
                  </td>
                </tr>
              `).join('')}
            </tbody>
          </table>
        </div>
      `;
    }
  }

  function getEstadoColor(estado: string) {
    const colors: Record<string, string> = {
      pendiente: 'bg-yellow-100 text-yellow-800',
      en_proceso: 'bg-blue-100 text-blue-800',
      completada: 'bg-green-100 text-green-800',
      cancelada: 'bg-red-100 text-red-800',
    };
    return colors[estado] || 'bg-gray-100 text-gray-800';
  }
</script>
