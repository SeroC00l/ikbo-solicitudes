---
import LayoutPrincipal from '@/layouts/LayoutPrincipal.astro';
import Sidebar from '@/components/auth/Sidebar.astro';

interface Props {
  title?: string;
}

const { title } = Astro.props;
---

<LayoutPrincipal title={title}>
  <div class="min-h-screen flex">
    <Sidebar />
    <main class="flex-1 p-8">
      <slot />
    </main>
  </div>
</LayoutPrincipal>
